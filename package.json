{
  "name": "careerpilot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace packages/shared",
    "typecheck:shared": "npm run typecheck --workspace packages/shared",
    "dev": "npm run dev --workspace apps/web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build": "npm run build:shared && npm run build --workspace apps/web && npm run build --workspace apps/api",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "typecheck": "npm run typecheck:shared && npm run typecheck --workspace apps/web && npm run typecheck --workspace apps/api",
    "typecheck:web": "npm run typecheck --workspace apps/web",
    "typecheck:api": "npm run typecheck --workspace apps/api",
    "lint": "npm run lint --workspace apps/web"
  }
}
