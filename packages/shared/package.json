{
  "name": "@careerpilot/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./types/copilot": {
      "types": "./src/types/copilot.ts",
      "default": "./dist/types/copilot.js"
    },
    "./types/jobs": {
      "types": "./src/types/jobs.ts",
      "default": "./dist/types/jobs.js"
    },
    "./types/rag": {
      "types": "./src/types/rag.ts",
      "default": "./dist/types/rag.js"
    },
    "./types/resume": {
      "types": "./src/types/resume.ts",
      "default": "./dist/types/resume.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  }
}
