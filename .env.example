# App
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000/api/v1
VITE_API_BASE_URL=http://localhost:4000/api/v1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DIRECT_URI=
MONGODB_DATABASE=careerpilot
MONGODB_VECTOR_SEARCH_INDEX=resume_chunks_vector_index

# Firebase Client
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudinary
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=careerpilot/resumes

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Jooble
JOOBLE_API_KEY=1831b3a1-2191-4922-8fed-a9d3dfaf7100

# Runtime
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:4173
LOG_LEVEL=info
